      "id": "Q156",
      "sql": "WITH extracted AS (SELECT _timestamp, sorter_model, array_extract(regexp_match(event_detail, 'batch ([A-Z0-9]+)'), 1) AS batch_id, array_extract(regexp_match(event_detail, 'segment ([0-9]+)'), 1) AS segment_nbr, array_extract(regexp_match(event_detail, 'track ([A-Za-z0-9-]+)'), 1) AS track_id FROM \"{stream}\" WHERE event_detail LIKE '%sorter batch%'), with_batch_flag AS (SELECT _timestamp, batch_id, sorter_model, segment_nbr, track_id, CASE WHEN array_extract(regexp_match(track_id, '([A-Z]+)'), 1) = 'TRK' THEN 'batch' ELSE 'non batch' END AS is_batch, concat('srt', lpad(CAST(segment_nbr AS VARCHAR), 5, '0'), '#', track_id) AS sorterWithTrackId FROM extracted), recovered_status AS (SELECT wbf.batch_id, wbf.sorter_model, wbf.segment_nbr, wbf.track_id, wbf.is_batch, wbf.sorterWithTrackId, CASE WHEN ack.ack_detail IS NOT NULL AND ack.ack_detail != '' THEN 'received' ELSE 'notreceived' END AS ack_status FROM with_batch_flag wbf LEFT JOIN (SELECT ack_detail FROM \"{stream}\" WHERE ack_detail IS NOT NULL AND ack_detail != '' AND str_match_ignore_case(ack_detail, 'ACK batch')) ack ON ack.ack_detail LIKE concat('%batchIdList:%', wbf.batch_id, '%') WHERE wbf.is_batch = 'batch') SELECT array_agg('batch_id-' || batch_id || ', sorter_model-' || sorter_model || ', segment_nbr-' || segment_nbr || ', track_id-' || track_id || ', is_batch-' || is_batch || ', sorterWithTrackId-' || sorterWithTrackId || ', ack_status-' || ack_status) AS results, COUNT(*) AS event_count FROM recovered_status HAVING COUNT(*) > 0",
