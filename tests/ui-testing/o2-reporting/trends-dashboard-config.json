    {
      "tabId": "flaky",
      "name": "Flaky & Failing",
      "panels": [
        {
          "id": "p_flaky_list",
          "type": "table",
          "title": "Flaky Tests (Mixed Pass/Fail Across Runs)",
          "description": "",
          "queryType": "",
          "queries": [
            {
              "query": "SELECT test_name, file_path, shard, COUNT(*) as total_runs, COUNT(CASE WHEN status = 'passed' THEN 1 END) as passes, COUNT(CASE WHEN status = 'failed' THEN 1 END) as failures, COUNT(CASE WHEN status = 'flaky' THEN 1 END) as flaky_count, ROUND(COUNT(CASE WHEN status = 'failed' THEN 1 END) * 100.0 / COUNT(*), 1) as failure_rate FROM e2e_playwright_reports WHERE shard IN ('SDR', 'RUM', 'Streams') GROUP BY test_name, file_path, shard HAVING COUNT(CASE WHEN status = 'failed' THEN 1 END) > 0 AND COUNT(CASE WHEN status = 'passed' THEN 1 END) > 0 ORDER BY failure_rate DESC LIMIT 30",
              "customQuery": true,
              "fields": {
                "stream": "e2e_playwright_reports",
                "stream_type": "logs",
                "x": [
                  {
                    "label": "Test",
