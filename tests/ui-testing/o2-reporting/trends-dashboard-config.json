                    "column": "file_path"
                  },
                  {
                    "label": "Shard",
                    "alias": "shard",
                    "column": "shard"
                  }
                ],
                "y": [
                  {
                    "label": "Total Runs",
                    "alias": "total_runs",
                    "column": "total_runs"
