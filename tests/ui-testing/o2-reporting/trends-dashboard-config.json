{
  "version": 8,
  "title": "E2E Playwright Test Trends",
  "description": "Cross-run trends — pass rates, flaky tests, error patterns, environment breakdown",
  "role": "",
  "owner": "",
  "tabs": [
    {
      "tabId": "trends",
      "name": "Trends",
      "panels": [
        {
          "id": "p_pass_rate_trend",
          "type": "line",
          "title": "Pass Rate Over Time (by Run)",
          "description": "",
          "queryType": "",
          "queries": [
            {
              "query": "SELECT run_id, ROUND(COUNT(CASE WHEN status = 'passed' THEN 1 END) * 100.0 / COUNT(*), 1) as pass_rate, COUNT(*) as total_tests FROM e2e_playwright_reports WHERE shard IN ('SDR', 'RUM', 'Streams') GROUP BY run_id ORDER BY MIN(_timestamp) DESC LIMIT 20",
              "customQuery": true,
              "fields": {
                "stream": "e2e_playwright_reports",
                "stream_type": "logs",
                "x": [
                  {
                    "label": "Run ID",
                    "alias": "run_id",
                    "column": "run_id"
                  }
                ],
                "y": [
                  {
                    "label": "Pass Rate %",
                    "alias": "pass_rate",
                    "column": "pass_rate"
                  }
                ],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": ""
              }
            }
          ],
          "config": {
            "show_legends": true
          },
          "layout": {
            "x": 0,
            "y": 0,
            "w": 192,
            "h": 10,
            "i": 1
          }
        },
        {
          "id": "p_failure_trend",
          "type": "bar",
          "title": "Failure Count Per Run",
          "description": "",
          "queryType": "",
          "queries": [
            {
              "query": "SELECT run_id, COUNT(CASE WHEN status = 'failed' THEN 1 END) as failures, COUNT(CASE WHEN status = 'passed' THEN 1 END) as passes FROM e2e_playwright_reports WHERE shard IN ('SDR', 'RUM', 'Streams') GROUP BY run_id ORDER BY MIN(_timestamp) DESC LIMIT 20",
              "customQuery": true,
              "fields": {
                "stream": "e2e_playwright_reports",
                "stream_type": "logs",
                "x": [
                  {
                    "label": "Run ID",
                    "alias": "run_id",
                    "column": "run_id"
                  }
                ],
                "y": [
                  {
                    "label": "Failures",
                    "alias": "failures",
                    "column": "failures"
                  },
                  {
                    "label": "Passes",
                    "alias": "passes",
                    "column": "passes"
                  }
                ],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
