        {
          "id": "p_shard_trend",
          "type": "line",
          "title": "Pass Rate by Shard Over Time",
          "description": "",
          "queryType": "",
          "queries": [
            {
              "query": "SELECT run_id, ROUND(SUM(CASE WHEN shard='SDR' AND status='passed' THEN 1 ELSE 0 END)*100.0/NULLIF(SUM(CASE WHEN shard='SDR' THEN 1 ELSE 0 END),0),1) as sdr_pass_rate, ROUND(SUM(CASE WHEN shard='RUM' AND status='passed' THEN 1 ELSE 0 END)*100.0/NULLIF(SUM(CASE WHEN shard='RUM' THEN 1 ELSE 0 END),0),1) as rum_pass_rate, ROUND(SUM(CASE WHEN shard='Streams' AND status='passed' THEN 1 ELSE 0 END)*100.0/NULLIF(SUM(CASE WHEN shard='Streams' THEN 1 ELSE 0 END),0),1) as streams_pass_rate FROM e2e_playwright_reports WHERE shard IN ('SDR', 'RUM', 'Streams') GROUP BY run_id ORDER BY MIN(_timestamp) ASC LIMIT 20",
              "customQuery": true,
              "fields": {
                "stream": "e2e_playwright_reports",
                "stream_type": "logs",
                "x": [
                  {
                    "label": "Run ID",
                    "alias": "run_id",
                    "column": "run_id"
                  }
                ],
                "y": [
                  {
                    "label": "SDR",
                    "alias": "sdr_pass_rate",
                    "column": "sdr_pass_rate"
                  },
                  {
                    "label": "RUM",
                    "alias": "rum_pass_rate",
                    "column": "rum_pass_rate"
                  },
                  {
                    "label": "Streams",
                    "alias": "streams_pass_rate",
                    "column": "streams_pass_rate"
                  }
                ],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": ""
              }
            }
          ],
          "config": {
            "show_legends": true
          },
          "layout": {
            "x": 0,
            "y": 20,
            "w": 192,
            "h": 10,
            "i": 3
          }
        },
        {
          "id": "p_duration_trend",
          "type": "line",
          "title": "Average Test Duration by Shard (s)",
          "description": "",
          "queryType": "",
          "queries": [
            {
              "query": "SELECT run_id, ROUND(AVG(CASE WHEN shard='SDR' THEN duration_secs END),1) as sdr_avg_secs, ROUND(AVG(CASE WHEN shard='RUM' THEN duration_secs END),1) as rum_avg_secs, ROUND(AVG(CASE WHEN shard='Streams' THEN duration_secs END),1) as streams_avg_secs FROM e2e_playwright_reports WHERE shard IN ('SDR', 'RUM', 'Streams') GROUP BY run_id ORDER BY MIN(_timestamp) ASC LIMIT 20",
              "customQuery": true,
              "fields": {
                "stream": "e2e_playwright_reports",
                "stream_type": "logs",
                "x": [
                  {
                    "label": "Run ID",
                    "alias": "run_id",
                    "column": "run_id"
                  }
                ],
                "y": [
                  {
                    "label": "SDR (s)",
                    "alias": "sdr_avg_secs",
                    "column": "sdr_avg_secs"
                  },
                  {
                    "label": "RUM (s)",
                    "alias": "rum_avg_secs",
                    "column": "rum_avg_secs"
                  },
                  {
                    "label": "Streams (s)",
                    "alias": "streams_avg_secs",
                    "column": "streams_avg_secs"
                  }
