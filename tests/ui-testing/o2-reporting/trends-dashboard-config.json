                  {
                    "label": "Passes",
                    "alias": "passes",
                    "column": "passes"
                  },
                  {
                    "label": "Failures",
                    "alias": "failures",
                    "column": "failures"
                  },
                  {
                    "label": "Flaky",
                    "alias": "flaky_count",
                    "column": "flaky_count"
                  },
                  {
                    "label": "Failure Rate %",
                    "alias": "failure_rate",
                    "column": "failure_rate"
                  }
                ],
                "z": [],
                "filter": {
                  "type": "list",
                  "values": [],
                  "logicalOperator": "AND",
                  "filterType": "list"
                }
              },
              "config": {
                "promql_legend": ""
              }
