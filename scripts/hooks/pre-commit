#!/usr/bin/env bash
# =============================================================================
# Pre-commit Hook: UI Unit Test Coverage Checker
# =============================================================================
# Checks staged UI files (web/src/**) for missing or stale spec files.
# When issues are found, offers three options:
#   1. Auto-generate tests using Claude Code CLI
#   2. Force-commit anyway (skip this check)
#   3. Abort — write tests manually
#
# Bypass entirely: SKIP_TEST_CHECK=1 git commit ...
# =============================================================================

set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
IGNORE_FILE="$REPO_ROOT/.test-ignore"

# ─── Colors ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ─── Bypass flags ─────────────────────────────────────────────────────────────
if [[ "${SKIP_TEST_CHECK:-}" == "1" ]]; then
  echo -e "${DIM}[pre-commit] Skipping unit test check (SKIP_TEST_CHECK=1)${NC}"
  exit 0
fi

# ─── Find claude CLI ──────────────────────────────────────────────────────────
find_claude() {
  # Check PATH first
  local from_path
  from_path="$(command -v claude 2>/dev/null)"
  if [[ -n "$from_path" && -x "$from_path" ]]; then
    echo "$from_path"
    return 0
  fi

  # Check all installed nvm node versions
  if [[ -d "$HOME/.nvm/versions/node" ]]; then
    local nvm_claude
    while IFS= read -r nvm_claude; do
      if [[ -x "$nvm_claude" ]]; then
        echo "$nvm_claude"
        return 0
      fi
    done < <(find "$HOME/.nvm/versions/node" -name "claude" -path "*/bin/claude" 2>/dev/null | sort -rV)
  fi

  # Other common install paths
  local candidates=(
    "/usr/local/bin/claude"
    "/opt/homebrew/bin/claude"
    "$HOME/.local/bin/claude"
    "$HOME/bin/claude"
  )
  for cmd in "${candidates[@]}"; do
    if [[ -x "$cmd" ]]; then
      echo "$cmd"
      return 0
    fi
  done

  return 1
}

# ─── Load .test-ignore patterns ───────────────────────────────────────────────
IGNORE_PATTERNS=()
if [[ -f "$IGNORE_FILE" ]]; then
  while IFS= read -r line; do
    # Skip comments and empty lines
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    IGNORE_PATTERNS+=("$line")
  done < "$IGNORE_FILE"
fi

is_ignored() {
  local file="$1"
  for pattern in "${IGNORE_PATTERNS[@]}"; do
    # Simple glob match against the file path
    # shellcheck disable=SC2254
    case "$file" in
      $pattern) return 0 ;;
    esac
  done
  return 1
}

# ─── Heuristic: does this file need unit tests? ───────────────────────────────
needs_tests() {
  local file="$1"   # repo-relative path
  local dirpath; dirpath="$(dirname "$file")"
  local basename; basename="$(basename "$file")"
  local full_path="$REPO_ROOT/$file"

  # Check .test-ignore overrides first
  is_ignored "$file" && return 1

  # Skip TypeScript declaration files
  [[ "$basename" =~ \.d\.ts$ ]] && return 1

  # ── Directories that don't need unit tests ──────────────────────────────────
  # Icons: usually simple SVG/font icon wrappers
  [[ "$dirpath" == */icons || "$dirpath" == */icons/* ]] && return 1
  # Static assets
  [[ "$dirpath" == */assets || "$dirpath" == */assets/* ]] && return 1
  # Internationalization strings
  [[ "$dirpath" == */locales || "$dirpath" == */locales/* ]] && return 1
  # Plugin registrations (vite/quasar plugins)
  [[ "$dirpath" == */plugins || "$dirpath" == */plugins/* ]] && return 1
  # CSS/SCSS styles
  [[ "$dirpath" == */styles || "$dirpath" == */styles/* ]] && return 1
  # Router config
  [[ "$dirpath" == */router || "$dirpath" == */router/* ]] && return 1
  # Mixin helpers (legacy Vue 2 pattern)
  [[ "$dirpath" == */mixins || "$dirpath" == */mixins/* ]] && return 1
  # Test helpers
  [[ "$dirpath" == */test || "$dirpath" == */test/* || "$dirpath" == */__tests__ ]] && return 1

  # ── File-level exclusions ────────────────────────────────────────────────────
  # App entry point (too broad for a unit test)
  [[ "$basename" == "main.ts" ]] && return 1
  # aws / cloud provider config files
  [[ "$basename" == "aws-exports.ts" ]] && return 1
  # Vite / build config files
  [[ "$basename" =~ \.(config|setup)\.(ts|js)$ ]] && return 1

  # ── Pure re-export index files ───────────────────────────────────────────────
  if [[ "$basename" == "index.ts" && -f "$full_path" ]]; then
    local non_export_lines
    non_export_lines=$(grep -cEv '^\s*(export|import|//|/\*|\*|$)' "$full_path" 2>/dev/null || echo "99")
    [[ "$non_export_lines" -lt 5 ]] && return 1
  fi

  # ── Directories that DO need tests ──────────────────────────────────────────
  # Services (HTTP/API layer)
  [[ "$dirpath" == */services || "$dirpath" == */services/* ]] && return 0
  # Composables (business logic hooks)
  [[ "$dirpath" == */composables || "$dirpath" == */composables/* ]] && return 0
  # Stores (Pinia/Vuex state)
  [[ "$dirpath" == */stores || "$dirpath" == */stores/* ]] && return 0

  # ── Vue SFC components ───────────────────────────────────────────────────────
  if [[ "$basename" =~ \.vue$ ]]; then
    # Skip very small components (< 40 lines) — they're likely trivial wrappers
    if [[ -f "$full_path" ]]; then
      local line_count
      line_count="$(wc -l < "$full_path" | tr -d ' ')"
      [[ "$line_count" -lt 40 ]] && return 1
    fi
    return 0
  fi

  # ── TypeScript files ─────────────────────────────────────────────────────────
  if [[ "$basename" =~ \.ts$ ]]; then
    return 0
  fi

  return 0
}

# ─── Derive spec file path ────────────────────────────────────────────────────
get_spec_path() {
  local file="$1"
  local ext="${file##*.}"
  local base="${file%.*}"
  echo "${base}.spec.${ext}"
}

# ─── Is the spec stale? ───────────────────────────────────────────────────────
# A spec is considered stale when:
#   - it exists but was NOT staged in this commit, AND
#   - it hasn't been touched in git for more than STALE_DAYS days
STALE_DAYS="${STALE_DAYS:-30}"

is_spec_stale() {
  local spec_file="$1"
  local full_spec="$REPO_ROOT/$spec_file"

  [[ ! -f "$full_spec" ]] && return 0   # Missing = definitely stale

  # If the spec is already staged in this commit, it's being updated — not stale
  git diff --cached --name-only | grep -qF "$spec_file" && return 1

  # Get the last commit timestamp for the spec file
  local spec_ts
  spec_ts="$(git log -1 --format="%at" -- "$spec_file" 2>/dev/null)"

  # Never committed → stale
  [[ -z "$spec_ts" ]] && return 0

  local threshold=$(( $(date +%s) - STALE_DAYS * 86400 ))
  [[ "$spec_ts" -lt "$threshold" ]] && return 0

  return 1
}

# ─── Auto-generate a test via Claude Code CLI ─────────────────────────────────
generate_test() {
  local source_file="$1"
  local spec_file="$2"
  local claude_cmd="$3"
  local full_source="$REPO_ROOT/$source_file"
  local full_spec="$REPO_ROOT/$spec_file"
  local ext="${source_file##*.}"

  echo -e "  ${CYAN}Generating:${NC} $spec_file"

  # Build context-aware prompt
  local source_content
  source_content="$(cat "$full_source")"

  # Gather a few existing spec examples for style reference
  local example_spec=""
  local example_file
  example_file="$(git ls-files "$REPO_ROOT/web/src" | grep '\.spec\.ts$' | head -1)"
  if [[ -n "$example_file" && -f "$REPO_ROOT/$example_file" ]]; then
    example_spec="$(head -60 "$REPO_ROOT/$example_file")"
  fi

  local prompt
  prompt="You are writing a unit test file for an OpenObserve UI (Vue 3 + TypeScript + Vitest).

OUTPUT ONLY raw TypeScript source code — no markdown, no explanation, no code fences.
Start directly with the Apache 2.0 license header comment.

━━━ SOURCE FILE TO TEST ━━━
Path: $source_file

\`\`\`$ext
$source_content
\`\`\`

━━━ REQUIREMENTS ━━━
- Framework: Vitest 4.x (import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest')
- For .vue files: also import { mount, shallowMount } from '@vue/test-utils'
- Mock all external imports (quasar, axios, vue-router, vuex/pinia stores) with vi.mock()
- Include Apache License 2.0 header with 'Copyright 2026 OpenObserve Inc.'
- Cover: happy paths, edge cases, error handling, and all exported functions/components
- Use describe() blocks organized by function / feature area

━━━ STYLE REFERENCE (first 60 lines of an existing spec) ━━━
$example_spec

━━━ OUTPUT ━━━
Write the complete test file for: $spec_file
Start immediately with the license header. No explanations."

  # Call Claude in print (non-interactive) mode
  local raw_output
  if ! raw_output="$("$claude_cmd" -p "$prompt" 2>/dev/null)"; then
    echo -e "  ${RED}✗ Claude returned a non-zero exit code for $source_file${NC}"
    return 1
  fi

  if [[ -z "$raw_output" ]]; then
    echo -e "  ${RED}✗ Claude returned empty output for $source_file${NC}"
    return 1
  fi

  # Strip markdown code fences if Claude added them anyway
  local code
  if echo "$raw_output" | grep -q '^\s*```'; then
    code="$(echo "$raw_output" | sed -n '/^\s*```/,/^\s*```$/p' | sed '1d;$d')"
  else
    code="$raw_output"
  fi

  if [[ -z "$code" ]]; then
    echo -e "  ${RED}✗ Could not extract code from Claude output for $source_file${NC}"
    return 1
  fi

  # Ensure parent directory exists
  mkdir -p "$(dirname "$full_spec")"
  echo "$code" > "$full_spec"
  git add "$full_spec"
  echo -e "  ${GREEN}✓ Generated and staged:${NC} $spec_file"
  return 0
}

# ─── Collect staged UI files ──────────────────────────────────────────────────
STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)"
[[ -z "$STAGED_FILES" ]] && exit 0

MISSING_TESTS=()
STALE_TESTS=()

while IFS= read -r file; do
  # Only care about web/src/**
  [[ ! "$file" =~ ^web/src/ ]] && continue

  # Skip spec files themselves
  [[ "$file" =~ \.spec\.(ts|tsx|js)$ ]] && continue

  # Only process Vue/TS/TSX files
  [[ ! "$file" =~ \.(vue|ts|tsx)$ ]] && continue

  # Skip declaration files
  [[ "$file" =~ \.d\.ts$ ]] && continue

  # Apply heuristic
  needs_tests "$file" || continue

  spec_path="$(get_spec_path "$file")"
  full_spec="$REPO_ROOT/$spec_path"

  if [[ ! -f "$full_spec" ]]; then
    MISSING_TESTS+=("$file")
  elif is_spec_stale "$spec_path"; then
    STALE_TESTS+=("$file")
  fi
done <<< "$STAGED_FILES"

# ─── All good → allow commit ──────────────────────────────────────────────────
if [[ ${#MISSING_TESTS[@]} -eq 0 && ${#STALE_TESTS[@]} -eq 0 ]]; then
  echo -e "${GREEN}[pre-commit] ✓ Unit test coverage check passed${NC}"
  exit 0
fi

# ─── Report issues ────────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}${RED}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${BOLD}${RED}│   ⚠  Unit Test Coverage Check Failed               │${NC}"
echo -e "${BOLD}${RED}└─────────────────────────────────────────────────────┘${NC}"
echo ""

if [[ ${#MISSING_TESTS[@]} -gt 0 ]]; then
  echo -e "${RED}  Missing spec files (${#MISSING_TESTS[@]}):${NC}"
  for f in "${MISSING_TESTS[@]}"; do
    echo -e "    ${YELLOW}✗${NC} $f"
    echo -e "      ${DIM}→ create: $(get_spec_path "$f")${NC}"
  done
  echo ""
fi

if [[ ${#STALE_TESTS[@]} -gt 0 ]]; then
  echo -e "${YELLOW}  Stale spec files — not updated in ${STALE_DAYS}+ days (${#STALE_TESTS[@]}):${NC}"
  for f in "${STALE_TESTS[@]}"; do
    echo -e "    ${YELLOW}⚠${NC}  $f"
    echo -e "      ${DIM}→ update: $(get_spec_path "$f")${NC}"
  done
  echo ""
fi

echo -e "${CYAN}  What would you like to do?${NC}"
echo ""
echo -e "    ${BOLD}[1]${NC}  Auto-generate tests with Claude Code"
echo -e "    ${BOLD}[2]${NC}  Force-commit anyway ${DIM}(I'll add tests soon)${NC}"
echo -e "    ${BOLD}[3]${NC}  Abort — I'll write the tests manually"
echo ""
echo -e "  ${DIM}Tip: export SKIP_TEST_CHECK=1 to bypass permanently${NC}"
echo ""

# Prompt — only works in interactive terminal
if ! exec < /dev/tty 2>/dev/null; then
  echo -e "${RED}  Non-interactive environment detected. Aborting commit.${NC}"
  echo -e "  ${DIM}Run with SKIP_TEST_CHECK=1 to bypass.${NC}"
  exit 1
fi

read -rp "  Choose [1/2/3]: " choice
echo ""

case "${choice:-3}" in
  1)
    CLAUDE_CMD=""
    if ! CLAUDE_CMD="$(find_claude)"; then
      echo -e "${RED}  Error: 'claude' CLI not found in PATH or common locations.${NC}"
      echo ""
      echo "  Install Claude Code:"
      echo "    npm install -g @anthropic-ai/claude-code"
      echo ""
      echo -e "  Or bypass: ${YELLOW}SKIP_TEST_CHECK=1 git commit ...${NC}"
      exit 1
    fi
    echo -e "  ${DIM}Using Claude at: $CLAUDE_CMD${NC}"
    echo ""

    ALL_OK=true
    for file in "${MISSING_TESTS[@]}" "${STALE_TESTS[@]}"; do
      spec="$(get_spec_path "$file")"
      generate_test "$file" "$spec" "$CLAUDE_CMD" || ALL_OK=false
    done

    echo ""
    if $ALL_OK; then
      echo -e "${GREEN}  All tests generated and staged. Proceeding with commit.${NC}"
      exit 0
    else
      echo -e "${RED}  Some tests could not be generated. Please create them manually.${NC}"
      exit 1
    fi
    ;;

  2)
    echo -e "${YELLOW}  Skipping test check. Please add missing tests before merging!${NC}"
    exit 0
    ;;

  *)
    echo -e "${RED}  Commit aborted. Please create the required spec files.${NC}"
    echo ""
    echo "  Quick guide:"
    for f in "${MISSING_TESTS[@]}" "${STALE_TESTS[@]}"; do
      echo "    touch $REPO_ROOT/$(get_spec_path "$f")"
    done
    exit 1
    ;;
esac
