# Copy to `.env` and fill in. These point the harness at your running
# OpenObserve backend (the same one the Playwright e2e suite uses).

# Backend the built frontend proxies to (auth + data). No trailing slash needed.
ZO_BACKEND_URL=http://localhost:5080

# Root credentials used to log in before measuring authenticated routes.
ZO_ROOT_USER_EMAIL=root@example.com
ZO_ROOT_USER_PASSWORD=Complexpass#123

# Organization whose data the benchmarked routes should load.
ORGNAME=default

# Optional: number of Lighthouse runs per route (median reported). Default 5.
# LH_RUNS=5
